<header>
  <style>
    .language-switcher {
      display: inline-flex;
      align-items: center;
      margin-left: 0.55rem;
      white-space: nowrap;
    }

    .language-switcher .language-option {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      color: var(--global-text-color-light);
      font-weight: inherit;
      line-height: inherit;
      text-decoration: none;
    }

    .language-switcher .language-option[data-lang-choice="zh"] {
      font-family: "Noto Sans SC", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", Roboto, sans-serif;
      font-weight: 400;
    }

    .language-switcher .language-option:hover {
      color: var(--global-hover-color);
      text-decoration: none;
    }

    .news-logo {
      display: inline-block;
      max-height: 1.35rem;
      max-width: 7rem;
      width: auto;
      margin-left: 0.45rem;
      vertical-align: -0.22rem;
    }

    .post > .profile {
      margin-top: 0.65rem;
    }

    .social {
      margin-top: 0.75rem;
      margin-bottom: 0;
    }

    .social .contact-icons {
      font-size: 2.6rem;
      line-height: 1;
    }

    .social .contact-icons a svg,
    .social .contact-icons a svg image,
    .social .contact-icons a img {
      width: 2.45rem;
      height: 2.45rem;
      margin-bottom: 0;
    }

    .social .contact-note:empty {
      display: none;
    }

    @media (min-width: 576px) {
      .publications ol.bibliography li .row > .abbr {
        flex: 0 0 34%;
        max-width: 34%;
      }

      .publications ol.bibliography li .row > div[id] {
        flex: 0 0 62%;
        max-width: 62%;
      }
    }

    .cv-entry-logo {
      display: block;
      max-height: 1.7rem;
      max-width: 5.3rem;
      width: auto;
      margin: 0.2rem auto 0;
      object-fit: contain;
    }

    .cv-entry-logo-fafu {
      max-height: 2.35rem;
      max-width: 6.8rem;
    }

    .cv-entry-logo-zju {
      max-height: 2.1rem;
      max-width: 6.85rem;
    }

    .table-cv .cv-date-badge {
      font-size: 0.74rem;
      white-space: nowrap;
    }

    .table-cv tr.cv-logo-row td {
      border-top: 0;
      padding-top: 0.35rem;
    }

    .cv .list-group > .list-group-item {
      list-style: none;
    }

    .cv .list-group > .list-group-item::marker {
      content: "";
    }

    .medium-zoom-image--opened {
      border-radius: 0 !important;
    }

    @media (max-width: 575.98px) {
      .language-switcher {
        margin-left: 0;
        margin-top: 0.35rem;
      }

      .news-logo {
        max-height: 1.15rem;
        max-width: 5.75rem;
      }

      .cv-entry-logo {
        max-width: 4.2rem;
      }

      .cv-entry-logo-fafu {
        max-width: 5.4rem;
      }

      .cv-entry-logo-zju {
        max-height: 1.9rem;
        max-width: 6.15rem;
      }
    }
  </style>
  <!-- Nav Bar -->
  <nav id="navbar" class="navbar navbar-light navbar-expand-sm {% if site.navbar_fixed %}fixed-top{% else %}sticky-top{% endif %}" role="navigation">
    <div class="container">
      {% assign is_zh = false %}
      {% if page.lang == 'zh' %}
        {% assign is_zh = true %}
      {% endif %}
      {% assign home_url = '/' %}
      {% if is_zh %}
        {% assign home_url = '/zh/' %}
      {% endif %}
      {% if page.permalink != '/' and page.permalink != '/zh/' %}
        <a class="navbar-brand title font-weight-lighter" href="{{ home_url | relative_url }}">
          {% if site.title == 'blank' %}
            {% if site.first_name %}
              <span class="font-weight-bold">
                {{- site.first_name -}}
              </span>
            {% endif %}
            {% if site.middle_name %}
              {{- site.middle_name -}}
            {% endif %}
            {% if site.last_name %}
              {{- site.last_name -}}
            {% endif %}
          {% else %}
            {% if is_zh %}郑华伟{% else %}{{- site.title -}}{% endif %}
          {% endif %}
        </a>
      {% elsif site.enable_navbar_social %}
        <!-- Social Icons -->
        <div class="navbar-brand social">{% social_links %}</div>
      {% endif %}
      <!-- Navbar Toggle -->
      <button
        class="navbar-toggler collapsed navbar-toggler-main"
        type="button"
        data-nav-toggle="navbarNav"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar top-bar"></span>
        <span class="icon-bar middle-bar"></span>
        <span class="icon-bar bottom-bar"></span>
      </button>

      <div class="collapse navbar-collapse navbar-collapse-main" id="navbarNav">
        {% if page.lang == 'zh' %}
          {% assign zh_url = page.url %}
          {% assign en_url = page.alternate_url | default: '/' %}
        {% else %}
          {% assign en_url = page.url %}
          {% assign zh_url = page.alternate_url | default: '/zh/' %}
        {% endif %}
        <ul class="navbar-nav navbar-menu-list flex-nowrap">
          {% for nav_page in site.pages %}
            {% if nav_page.permalink == '/' %} {% assign about_title = nav_page.title %} {% endif %}
          {% endfor %}

          <!-- About -->
          <li class="nav-item {% if page.permalink == '/' or page.permalink == '/zh/' %}active{% endif %}">
            <a
              class="nav-link"
              href="{{ home_url | relative_url }}"
              data-en-url="{{ '/' | relative_url }}"
              data-zh-url="{{ '/zh/' | relative_url }}"
              data-en-text="{{ about_title }}"
              data-zh-text="关于"
            >
              {% if is_zh %}关于{% else %}{{- about_title }}{% endif %}
              {% if page.permalink == '/' or page.permalink == '/zh/' %}
                <span class="sr-only">(current)</span>
              {% endif %}
            </a>
          </li>

          <!-- Other pages -->
          {% assign sorted_pages = site.pages | sort: 'nav_order' %}
          {% for p in sorted_pages %}
            {% if p.nav and p.autogen == null %}
              {% if p.dropdown %}
                {% assign has_active_child = false %}
                {% for child in p.children %}
                  {% if page.title == child.title %}
                    {% assign has_active_child = true %}
                  {% endif %}
                {% endfor %}
                <li class="nav-item dropdown {% if page.title == p.title or has_active_child %}active{% endif %}">
                  <a
                    class="nav-link dropdown-toggle"
                    href="#"
                    id="navbarDropdown"
                    role="button"
                    data-nav-dropdown-toggle="true"
                    aria-haspopup="true"
                    aria-expanded="false"
                  >
                    {{- p.title }}
                    {% if page.title == p.title or has_active_child %}
                      <span class="sr-only">(current)</span>
                    {% endif %}
                  </a>
                  <div class="dropdown-menu dropdown-menu-right" aria-labelledby="navbarDropdown">
                    {% for child in p.children %}
                      {% if child.title == 'divider' %}
                        <div class="dropdown-divider"></div>
                      {% else %}
                        <a
                          class="dropdown-item {% if page.title == child.title %}active{% endif %}"
                          href="{% if child.permalink contains '://' %}{{ child.permalink }}{% else %}{{ child.permalink | relative_url }}{% endif %}"
                        >
                          {{- child.title -}}
                        </a>
                      {% endif %}
                    {% endfor %}
                  </div>
                </li>
              {% else %}
                {% assign parent_link = p.permalink | remove: 'index.html' %}
                {% if p.permalink contains '://' %}
                  {% assign url = p.permalink %}
                {% elsif p.permalink contains '/blog/' %}
                  {% assign url = '/blog/' %}
                {% else %}
                  {% assign url = p.url %}
                {% endif %}
                {% assign nav_title = p.title %}
                {% assign is_active = false %}
                {% if page.url contains parent_link %}
                  {% assign is_active = true %}
                {% endif %}
                {% if is_zh and p.permalink == '/publications/' %}
                  {% assign url = '/zh/publications/' %}
                  {% assign nav_title = '论文' %}
                  {% if page.permalink == '/zh/publications/' %}
                    {% assign is_active = true %}
                  {% else %}
                    {% assign is_active = false %}
                  {% endif %}
                {% endif %}
                {% if is_zh and p.permalink == '/cv/' %}
                  {% assign url = '/zh/cv/' %}
                  {% assign nav_title = '简历' %}
                  {% if page.permalink == '/zh/cv/' %}
                    {% assign is_active = true %}
                  {% else %}
                    {% assign is_active = false %}
                  {% endif %}
                {% endif %}
                <li class="nav-item {% if is_active %}active{% endif %}">
                  <a
                    class="nav-link"
                    href="{{ url | relative_url }}"
                    {% if p.permalink == '/publications/' %}
                      data-en-url="{{ '/publications/' | relative_url }}"
                      data-zh-url="{{ '/zh/publications/' | relative_url }}"
                      data-en-text="{{ p.title }}"
                      data-zh-text="论文"
                    {% endif %}
                    {% if p.permalink == '/cv/' %}
                      data-en-url="{{ '/cv/' | relative_url }}"
                      data-zh-url="{{ '/zh/cv/' | relative_url }}"
                      data-en-text="{{ p.title }}"
                      data-zh-text="简历"
                    {% endif %}
                  >
                    {{- nav_title }}
                    {% if is_active %}
                      <span class="sr-only">(current)</span>
                    {% endif %}
                  </a>
                </li>
              {% endif %}
            {% endif %}
          {% endfor %}
          {% if site.enable_darkmode %}
            <!-- Toogle theme mode -->
            <li class="toggle-container">
              <button id="light-toggle" type="button" title="Change theme" aria-label="Change color theme">
                <i class="fa-half-sun-moon" id="light-toggle-system"></i>
                <i class="fa-solid fa-moon" id="light-toggle-dark"></i>
                <i class="fa-solid fa-sun" id="light-toggle-light"></i>
              </button>
            </li>
          {% endif %}
          <li class="nav-item language-switcher" aria-label="Language switcher">
            {% if is_zh %}
              <a class="language-option" href="{{ en_url | relative_url }}" data-lang-choice="en" aria-label="Switch to English">EN</a>
            {% else %}
              <a class="language-option" href="{{ zh_url | relative_url }}" data-lang-choice="zh" aria-label="切换到中文">中文</a>
            {% endif %}
          </li>
        </ul>
      </div>
    </div>
  </nav>
  <script>
    (function () {
      var storageKey = "preferredLanguage";
      var currentLang = "{{ page.lang | default: site.lang | default: 'en' }}";
      var alternateUrl = "{{ page.alternate_url | default: '' | relative_url }}";

      function updateStoredLanguage(lang) {
        try {
          window.localStorage.setItem(storageKey, lang);
        } catch (error) {
          return;
        }
      }

      function getStoredLanguage() {
        try {
          return window.localStorage.getItem(storageKey);
        } catch (error) {
          return null;
        }
      }

      function updateNavLinks(lang) {
        document.querySelectorAll("[data-en-url][data-zh-url]").forEach(function (link) {
          var nextUrl = link.getAttribute("data-" + lang + "-url");
          var nextText = link.getAttribute("data-" + lang + "-text");

          if (nextUrl) {
            link.setAttribute("href", nextUrl);
          }

          if (nextText) {
            var currentMarker = link.querySelector(".sr-only");
            link.textContent = nextText;

            if (currentMarker) {
              link.appendChild(currentMarker);
            }
          }
        });
      }

      document.querySelectorAll("[data-lang-choice]").forEach(function (link) {
        link.addEventListener("click", function () {
          updateStoredLanguage(link.getAttribute("data-lang-choice"));
        });
      });

      var preferredLang = getStoredLanguage();

      if (!preferredLang && currentLang === "zh") {
        updateStoredLanguage("zh");
        preferredLang = "zh";
      }

      if (!preferredLang) {
        preferredLang = "en";
      }

      updateNavLinks(preferredLang);

      if (preferredLang !== currentLang && alternateUrl && window.location.pathname !== alternateUrl) {
        window.location.replace(alternateUrl + window.location.search + window.location.hash);
      }
    })();

    (function () {
      document.addEventListener("DOMContentLoaded", function () {
        if (typeof mediumZoom !== "function") {
          return;
        }

        var zoomableImages = Array.prototype.slice.call(document.querySelectorAll("[data-zoomable]"));

        if (!zoomableImages.length) {
          return;
        }

        zoomableImages.forEach(function (image) {
          image.removeAttribute("data-zoomable");
        });

        function getZoomMargin() {
          return Math.round(Math.max(window.innerWidth, window.innerHeight) * 0.1);
        }

        var zoom = mediumZoom(zoomableImages, {
          margin: getZoomMargin(),
          background: getComputedStyle(document.documentElement).getPropertyValue("--global-bg-color") + "ee",
        });

        window.addEventListener("resize", function () {
          zoom.update({ margin: getZoomMargin() });
        });
      });
    })();

    (function () {
      document.addEventListener("DOMContentLoaded", function () {
        if ("{{ page.lang | default: site.lang | default: 'en' }}" !== "zh") {
          return;
        }

        var bibSearchInput = document.getElementById("bibsearch");

        if (bibSearchInput) {
          bibSearchInput.setAttribute("placeholder", "输入关键词筛选论文");
        }
      });
    })();

    {% if page.toc and page.toc.sidebar %}
      (function () {
        document.addEventListener("DOMContentLoaded", function () {
          var toc = document.getElementById("toc-sidebar");
          var main = document.querySelector('[role="main"]');

          if (!toc || !main) {
            return;
          }

          function isTocVisible() {
            return window.getComputedStyle(toc).visibility !== "hidden" && toc.offsetHeight > 0;
          }

          function getTocEntries() {
            return Array.prototype.slice
              .call(toc.querySelectorAll('a[href^="#"]'))
              .map(function (link) {
                var id = link.getAttribute("href").slice(1);
                var heading = document.getElementById(decodeURIComponent(id));

                return heading ? { link: link, heading: heading } : null;
              })
              .filter(Boolean);
          }

          function syncActiveTocLink() {
            if (!isTocVisible()) {
              return;
            }

            var entries = getTocEntries();

            if (!entries.length) {
              return;
            }

            var active = entries[0];
            var offset = 96;

            entries.forEach(function (entry) {
              if (entry.heading.getBoundingClientRect().top <= offset) {
                active = entry;
              }
            });

            toc.querySelectorAll(".is-active-link").forEach(function (link) {
              link.classList.remove("is-active-link");
            });
            toc.querySelectorAll(".is-active-li").forEach(function (item) {
              item.classList.remove("is-active-li");
            });

            active.link.classList.add("is-active-link");

            var activeItem = active.link.closest("li");
            if (activeItem) {
              activeItem.classList.add("is-active-li");
            }

            var tocRect = toc.getBoundingClientRect();
            var linkRect = active.link.getBoundingClientRect();

            if (linkRect.top < tocRect.top || linkRect.bottom > tocRect.bottom) {
              active.link.scrollIntoView({ block: "nearest" });
            }
          }

          var scheduled = false;

          function scheduleSync() {
            if (scheduled) {
              return;
            }

            scheduled = true;
            window.requestAnimationFrame(function () {
              scheduled = false;
              syncActiveTocLink();
            });
          }

          window.addEventListener("scroll", scheduleSync, { passive: true });
          window.addEventListener("resize", scheduleSync);
          toc.addEventListener("click", function () {
            window.setTimeout(syncActiveTocLink, 350);
          });

          window.setTimeout(syncActiveTocLink, 250);
          window.setTimeout(syncActiveTocLink, 750);
        });
      })();
    {% endif %}

  </script>
  {% if site.enable_progressbar %}
    <!-- Scrolling Progress Bar -->
    <progress id="progress" value="0">
      <div class="progress-container">
        <span class="progress-bar"></span>
      </div>
    </progress>
  {% endif %}
</header>
